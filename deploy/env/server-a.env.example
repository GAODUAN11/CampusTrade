# Copy this file to server-a.env and edit values before startup.
# Keep KEY=VALUE format so both shell scripts and systemd EnvironmentFile can read it.

CAMPUS_MYSQL_HOST=127.0.0.1
CAMPUS_MYSQL_PORT=3306
CAMPUS_MYSQL_USERNAME=root
CAMPUS_MYSQL_PASSWORD=200662.Gd

# Optional: switch to RPC demo mode.
# SPRING_PROFILES_ACTIVE=rpc

# Required in RPC profile.
CAMPUS_REGISTRY_ENABLED=false
CAMPUS_REGISTRY_HOST=127.0.0.1
CAMPUS_REGISTRY_RPC_PORT=9090
CAMPUS_RPC_ADVERTISE_HOST=127.0.0.1

# Toggle each service on this machine.
ENABLE_USER_SERVICE_ON_A=true
ENABLE_PRODUCT_SERVICE_ON_A=true
ENABLE_FAVORITE_STANDBY_ON_A=false

# Per-service HTTP/RPC ports.
USER_SERVICE_HTTP_PORT=8081
USER_SERVICE_RPC_PORT=9091
PRODUCT_SERVICE_HTTP_PORT=8082
PRODUCT_SERVICE_RPC_PORT=9092
FAVORITE_A_HTTP_PORT=8083
FAVORITE_A_RPC_PORT=9093

JAVA_OPTS="-Xms256m -Xmx512m"

START_TIMEOUT_SECONDS=120
